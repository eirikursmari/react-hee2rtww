# Copy this file to .env and fill in your values.
# Never commit .env to git.

# OpenAI — used for generating vector embeddings
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — used for metadata extraction (classifier + societal impact)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase — used for storing expositions, embeddings, and extracted metadata
# Find these in your Supabase project: Settings → API
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # use the service_role key, not the anon key
